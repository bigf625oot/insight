服务器 B
# /opt/insight/docker-compose.yml
version: '3.8'

networks:
  insight:
    driver: bridge

volumes:
  pg_data:
  neo4j_data:
  neo4j_logs:
  redis_data:
  mongo_data:

services:
  # ===== PostgreSQL (含 pgvector) =====
  postgresql:
    image: pgvector/pgvector:pg16
    container_name: postgresql
    ports:
      - "10.0.0.2:5432:5432"
    environment:
      POSTGRES_DB: insight_menu
      POSTGRES_USER: insight_admin
      POSTGRES_PASSWORD: ${PG_PASS}
    volumes:
      - pg_data:/var/lib/postgresql/data
      - ./pg_init:/docker-entrypoint-initdb.d
    command: |
      postgres
      -c shared_buffers=4GB
      -c effective_cache_size=12GB
      -c work_mem=32MB
      -c maintenance_work_mem=512MB
      -c max_connections=150
      -c wal_level=replica
      -c max_wal_size=4GB
      -c timezone='Asia/Shanghai'
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U insight_admin -d insight_menu"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ===== Neo4j =====
  neo4j:
    image: neo4j:5-community
    container_name: neo4j
    ports:
      - "10.0.0.2:7474:7474"
      - "10.0.0.2:7687:7687"
    environment:
      NEO4J_AUTH: neo4j/${NEO4J_PASS}
      NEO4J_server_memory_heap_initial__size: 2G
      NEO4J_server_memory_heap_max__size: 2G
      NEO4J_server_memory_pagecache_size: 3G
      NEO4J_PLUGINS: '["apoc"]'
    volumes:
      - neo4j_data:/data
      - neo4j_logs:/logs
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "echo 'RETURN 1' | cypher-shell -u neo4j -p ${NEO4J_PASS} --format plain || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5

  # ===== Redis =====
  redis:
    image: redis:7-alpine
    container_name: redis
    ports:
      - "10.0.0.2:6379:6379"
    command: |
      redis-server
      --maxmemory 2gb
      --maxmemory-policy allkeys-lru
      --appendonly yes
      --appendfsync everysec
      --requirepass ${REDIS_PASS}
    volumes:
      - redis_data:/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASS}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ===== MongoDB =====
  mongo:
    image: mongo:7
    container_name: mongo
    ports:
      - "10.0.0.2:27017:27017"
    environment:
      MONGO_INITDB_ROOT_USERNAME: fastgpt
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_PASS}
    command: mongod --wiredTigerCacheSizeGB 0.5 --syncdelay 60
    volumes:
      - mongo_data:/data/db
    restart: unless-stopped
