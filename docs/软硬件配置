4.2 PostgreSQL 16（含 pgvector）
# postgresql.conf — 16C32G 服务器上与 Neo4j/Redis 共享
listen_addresses = '0.0.0.0'
max_connections = 150              # 预留 50 给 Neo4j/Redis/Mongo

# 内存（留足给其他服务）
shared_buffers = 4GB               # 物理内存的 12.5%
effective_cache_size = 12GB        # 留给 PG 的文件缓存估算
work_mem = 32MB                    # 并发高时保持小值
maintenance_work_mem = 512MB

# WAL
wal_level = replica
max_wal_size = 4GB
min_wal_size = 1GB
wal_keep_size = 2GB                # 保留足够 WAL 供备份

# 查询
random_page_cost = 1.1             # SSD
effective_io_concurrency = 200
shared_preload_libraries = 'pg_stat_statements, pg_trgm, vector'

# 时区
timezone = 'Asia/Shanghai'
log_timezone = 'Asia/Shanghai'

# 日志
log_min_duration_statement = 500ms  # 记录慢于 500ms 的查询
log_line_prefix = '%t [%p]: [%l-1] user=%u,db=%d,app=%a '
