class EmbeddingService:
    def __init__(self):
        self.model_name = "BAAI/bge-small-zh-v1.5"
        self.dimension = 512
        self.endpoint = os.getenv("EMBEDDING_ENDPOINT", "http://127.0.0.1:8082")
        self.mode = os.getenv("EMBEDDING_MODE", "local")

    async def embed_text(self, text: str) -> list[float]:
        if self.mode == "api":
            return await self._call_api(text)
        else:
            return await self._call_local(text)

    async def embed_query(self, query: str) -> list[float]:
        """BGE 系列查询需加 instruction 前缀"""
        return await self.embed_text(
            f"为这个句子生成表示以用于检索相关文章：{query}"
        )

    async def embed_batch(self, texts: list[str]) -> list[list[float]]:
        """批量向量化，知识库入库使用"""
